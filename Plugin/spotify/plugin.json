{
  "id": "spotify",
  "name": "Spotify",
  "version": "1.0.0",
  "description": "Spotify playback control (requires refresh token)",
  "homepage": "https://developer.spotify.com/documentation/web-api/",
  "instructions": "Create a Spotify app, generate a refresh token, then enter Client ID, Client Secret, and Refresh Token.",
  "config": [
    {"key": "client_id", "label": "Client ID", "secret": false},
    {"key": "client_secret", "label": "Client Secret", "secret": true},
    {"key": "refresh_token", "label": "Refresh Token", "secret": true}
  ],
  "actions": [
    {
      "id": "play",
      "name": "Play",
      "type": "spotify_request",
      "method": "PUT",
      "url": "https://api.spotify.com/v1/me/player/play",
      "body": "{}"
    },
    {
      "id": "pause",
      "name": "Pause",
      "type": "spotify_request",
      "method": "PUT",
      "url": "https://api.spotify.com/v1/me/player/pause",
      "body": "{}"
    },
    {
      "id": "next",
      "name": "Next Track",
      "type": "spotify_request",
      "method": "POST",
      "url": "https://api.spotify.com/v1/me/player/next",
      "body": "{}"
    },
    {
      "id": "previous",
      "name": "Previous Track",
      "type": "spotify_request",
      "method": "POST",
      "url": "https://api.spotify.com/v1/me/player/previous",
      "body": "{}"
    }
  ]
}
